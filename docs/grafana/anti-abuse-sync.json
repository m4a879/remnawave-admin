{
  "annotations": { "list": [
    { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts", "type": "dashboard" }
  ]},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "type": "dashboards", "tags": ["remnawave","overview"], "asDropdown": false, "includeVars": true, "keepTime": true, "targetBlank": false }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "title": "Open violations", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 5 },
        { "color": "red", "value": 25 }
      ]}, "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_violations_open{instance=~\"$instance\"}", "legendFormat": "open" }]
    },
    {
      "id": 2, "title": "Torrent events (24h)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 10 },
        { "color": "red", "value": 100 }
      ]}, "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_torrent_events_24h{instance=~\"$instance\"}", "legendFormat": "events" }]
    },
    {
      "id": 3, "title": "Collector rate", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(rate(panel_collector_batches_received_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "batches/s" }]
    },
    {
      "id": 4, "title": "Reject rate (24h)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "description": "Доля reject'ов от всех попыток collector/batch за окно",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 0.05 },
        { "color": "red", "value": 0.2 }
      ]}, "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(rate(panel_collector_batches_rejected_total{instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(panel_collector_batches_received_total{instance=~\"$instance\"}[$__rate_interval])) + sum(rate(panel_collector_batches_rejected_total{instance=~\"$instance\"}[$__rate_interval])), 0.001)", "legendFormat": "ratio" }]
    },
    {
      "id": 5, "title": "Violations by recommended action", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "description": "Open violations grouped by action (gauge from DB).",
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["last","max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }, "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_violations_by_action{instance=~\"$instance\"}", "legendFormat": "{{action}}" }]
    },
    {
      "id": 6, "title": "Violations detected rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "description": "Counter — приращение новых violations per second by action.",
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (action) (rate(panel_violations_detected_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{action}}" }]
    },
    {
      "id": 7, "title": "Collector batches & connections (rate)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "unit": "ops" }, "overrides": [
        { "matcher": { "id": "byName", "options": "rejected" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
      ]},
      "targets": [
        { "refId": "A", "expr": "sum(rate(panel_collector_batches_received_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "received" },
        { "refId": "B", "expr": "sum(rate(panel_collector_batches_rejected_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "rejected" },
        { "refId": "C", "expr": "sum(rate(panel_collector_connections_processed_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "connections/s" }
      ]
    },
    {
      "id": 8, "title": "Reject reasons", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (reason) (rate(panel_collector_batches_rejected_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{reason}}" }]
    },
    {
      "id": 9, "title": "Notifications sent (rate)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["sum","mean"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (channel) (rate(panel_notifications_sent_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{channel}} ok" },
        { "refId": "B", "expr": "sum by (channel) (rate(panel_notifications_failed_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{channel}} failed" }
      ]
    },
    {
      "id": 10, "title": "Sync lag (seconds)", "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "description": "Время от последнего успешного sync per kind. Большие значения — что-то заклинило.",
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 300 },
        { "color": "red", "value": 1800 }
      ]}, "unit": "s" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_sync_lag_seconds{instance=~\"$instance\"}", "legendFormat": "{{kind}}" }]
    },
    {
      "id": 11, "title": "Sync runs (errors per kind)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "unit": "ops" }, "overrides": [
        { "matcher": { "id": "byRegexp", "options": "/error/" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
      ]},
      "targets": [{ "refId": "A", "expr": "sum by (kind, result) (rate(panel_sync_runs_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{kind}} {{result}}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["remnawave", "panel", "abuse", "sync"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "options": [], "refresh": 1, "skipUrlSync": false },
      { "name": "instance", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(panel_online_users, instance)", "current": { "selected": false, "text": "All", "value": "$__all" }, "hide": 0, "includeAll": true, "label": "Instance", "multi": true, "options": [], "refresh": 2, "regex": "", "skipUrlSync": false, "sort": 1 }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Remnawave Admin — Anti-abuse & Sync",
  "uid": "remnawave-panel-abuse",
  "version": 1,
  "weekStart": ""
}
