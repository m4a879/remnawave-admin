{
  "annotations": { "list": [
    { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts", "type": "dashboard" }
  ]},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "type": "dashboards", "tags": ["remnawave","overview"], "asDropdown": false, "includeVars": true, "keepTime": true, "targetBlank": false }
  ],
  "liveNow": false,
  "panels": [
    { "id": 100, "type": "row", "title": "KPI", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },

    {
      "id": 1, "title": "Nodes online", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.99 }
      ]}, "unit": "percentunit", "min": 0, "max": 1, "decimals": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(panel_node_connected{instance=~\"$instance\"}) / clamp_min(count(panel_node_connected{instance=~\"$instance\"}), 1)", "legendFormat": "" }]
    },
    {
      "id": 2, "title": "Avg CPU", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 85 }
      ]}, "unit": "percent", "min": 0, "max": 100, "decimals": 1 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "avg(panel_node_cpu_usage_percent{instance=~\"$instance\"})", "legendFormat": "" }]
    },
    {
      "id": 3, "title": "Max RAM", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "description": "Наиболее загруженная нода по памяти",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
      ]}, "unit": "percent", "min": 0, "max": 100, "decimals": 1 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "topk(1, panel_node_memory_usage_percent{instance=~\"$instance\"})", "legendFormat": "{{node}}" }]
    },
    {
      "id": 4, "title": "Max disk", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "description": "Наиболее заполненный диск",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
      ]}, "unit": "percent", "min": 0, "max": 100, "decimals": 1 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "topk(1, panel_node_disk_usage_percent{instance=~\"$instance\"})", "legendFormat": "{{node}}" }]
    },
    {
      "id": 5, "title": "Total traffic (all nodes)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "bytes" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(panel_node_traffic_used_bytes{instance=~\"$instance\"})", "legendFormat": "" }]
    },
    {
      "id": 6, "title": "Stalest (last seen)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "description": "Самая отстающая нода по времени последнего отчёта.",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background_solid", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 120 }, { "color": "red", "value": 600 }
      ]}, "unit": "s" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "topk(1, panel_node_last_seen_seconds{instance=~\"$instance\"})", "legendFormat": "{{node}}" }]
    },

    { "id": 101, "type": "row", "title": "Состояние нод", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "panels": [] },

    {
      "id": 10, "title": "Node status", "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 7 },
      "description": "Единая сводка. CPU/RAM/Disk цветовые градиенты, last-seen зелёный <120с / оранж <300 / красный больше.",
      "options": { "showHeader": true, "footer": { "show": false }, "cellHeight": "sm" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Connected" }, "properties": [
          { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
          { "id": "custom.width", "value": 110 },
          { "id": "mappings", "value": [ { "type": "value", "options": { "1": { "text": "yes", "color": "green", "index": 0 }, "0": { "text": "no", "color": "red", "index": 1 } } } ] },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }
        ]},
        { "matcher": { "id": "byName", "options": "Last seen" }, "properties": [
          { "id": "unit", "value": "s" },
          { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "orange", "value": 120 }, { "color": "red", "value": 300 }
          ]}}
        ]},
        { "matcher": { "id": "byName", "options": "CPU" }, "properties": [
          { "id": "unit", "value": "percent" }, { "id": "min", "value": 0 }, { "id": "max", "value": 100 }, { "id": "decimals", "value": 1 },
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 85 }] } }
        ]},
        { "matcher": { "id": "byName", "options": "RAM" }, "properties": [
          { "id": "unit", "value": "percent" }, { "id": "min", "value": 0 }, { "id": "max", "value": 100 }, { "id": "decimals", "value": 1 },
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] } }
        ]},
        { "matcher": { "id": "byName", "options": "Disk" }, "properties": [
          { "id": "unit", "value": "percent" }, { "id": "min", "value": 0 }, { "id": "max", "value": 100 }, { "id": "decimals", "value": 1 },
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] } }
        ]},
        { "matcher": { "id": "byName", "options": "Uptime" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "custom.width", "value": 110 } ] },
        { "matcher": { "id": "byName", "options": "Traffic" }, "properties": [ { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 130 } ] },
        { "matcher": { "id": "byName", "options": "Cores" }, "properties": [ { "id": "custom.width", "value": 70 }, { "id": "unit", "value": "short" } ] }
      ]},
      "targets": [
        { "refId": "A", "expr": "panel_node_connected{instance=~\"$instance\"}",            "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "B", "expr": "panel_node_last_seen_seconds{instance=~\"$instance\"}",    "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "C", "expr": "panel_node_cpu_usage_percent{instance=~\"$instance\"}",    "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "D", "expr": "panel_node_memory_usage_percent{instance=~\"$instance\"}", "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "E", "expr": "panel_node_disk_usage_percent{instance=~\"$instance\"}",   "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "F", "expr": "panel_node_uptime_seconds{instance=~\"$instance\"}",       "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "G", "expr": "panel_node_traffic_used_bytes{instance=~\"$instance\"}",   "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "H", "expr": "panel_node_cpu_cores{instance=~\"$instance\"}",            "legendFormat": "{{node}}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "node", "mode": "outer" } },
        { "id": "organize", "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
              "Time 5": true, "Time 6": true, "Time 7": true, "Time 8": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "__name__ 3": true, "__name__ 4": true, "__name__ 5": true,
              "__name__ 6": true, "__name__ 7": true, "__name__ 8": true,
              "job": true, "job 1": true, "job 2": true, "job 3": true,
              "job 4": true, "job 5": true, "job 6": true, "job 7": true, "job 8": true,
              "instance": true, "instance 1": true, "instance 2": true, "instance 3": true,
              "instance 4": true, "instance 5": true, "instance 6": true, "instance 7": true, "instance 8": true,
              "service": true, "service 1": true, "service 2": true, "service 3": true,
              "service 4": true, "service 5": true, "service 6": true, "service 7": true, "service 8": true,
              "instance_name": true, "instance_name 1": true, "instance_name 2": true, "instance_name 3": true,
              "instance_name 4": true, "instance_name 5": true, "instance_name 6": true, "instance_name 7": true, "instance_name 8": true
            },
            "indexByName": { "node": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4, "Value #E": 5, "Value #F": 6, "Value #G": 7, "Value #H": 8 },
            "renameByName": { "node": "Node", "Value #A": "Connected", "Value #B": "Last seen", "Value #C": "CPU", "Value #D": "RAM", "Value #E": "Disk", "Value #F": "Uptime", "Value #G": "Traffic", "Value #H": "Cores" }
        }}
      ]
    },

    { "id": 102, "type": "row", "title": "CPU и память", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "panels": [] },

    {
      "id": 20, "title": "Per-node CPU %", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 19 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean","max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_node_cpu_usage_percent{instance=~\"$instance\"}", "legendFormat": "{{node}}" }]
    },
    {
      "id": 21, "title": "Per-node RAM %", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 19 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean","max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_node_memory_usage_percent{instance=~\"$instance\"}", "legendFormat": "{{node}}" }]
    },
    {
      "id": 22, "title": "Per-node RAM (used)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 28 },
      "description": "Реальные байты в употреблении.",
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["last","max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true, "showPoints": "never" }, "unit": "bytes" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_node_memory_used_bytes{instance=~\"$instance\"}", "legendFormat": "{{node}}" }]
    },
    {
      "id": 23, "title": "RAM per node", "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 28 },
      "description": "Total / Used / Free + процент. Free = total - used (вычисляется на лету).",
      "options": { "showHeader": true, "footer": { "show": false }, "cellHeight": "sm" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Total" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
        ]},
        { "matcher": { "id": "byName", "options": "Used" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
        ]},
        { "matcher": { "id": "byName", "options": "Free" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
        ]},
        { "matcher": { "id": "byName", "options": "Usage" }, "properties": [
          { "id": "unit", "value": "percentunit" }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 }, { "id": "decimals", "value": 1 },
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 0.9 }
          ]}}
        ]}
      ]},
      "targets": [
        { "refId": "A", "expr": "panel_node_memory_total_bytes{instance=~\"$instance\"}", "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "B", "expr": "panel_node_memory_used_bytes{instance=~\"$instance\"}",  "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "C", "expr": "panel_node_memory_total_bytes{instance=~\"$instance\"} - panel_node_memory_used_bytes{instance=~\"$instance\"}", "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "D", "expr": "panel_node_memory_used_bytes{instance=~\"$instance\"} / clamp_min(panel_node_memory_total_bytes{instance=~\"$instance\"}, 1)", "legendFormat": "{{node}}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "node", "mode": "outer" } },
        { "id": "organize", "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
              "job": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true,
              "instance": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true,
              "service": true, "service 1": true, "service 2": true, "service 3": true, "service 4": true,
              "instance_name": true, "instance_name 1": true, "instance_name 2": true, "instance_name 3": true, "instance_name 4": true
            },
            "indexByName": { "node": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4 },
            "renameByName": { "node": "Node", "Value #A": "Total", "Value #B": "Used", "Value #C": "Free", "Value #D": "Usage" }
        }}
      ]
    },

    { "id": 103, "type": "row", "title": "Диск", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }, "panels": [] },

    {
      "id": 30, "title": "Per-node disk %", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 38 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["last","max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_node_disk_usage_percent{instance=~\"$instance\"}", "legendFormat": "{{node}}" }]
    },
    {
      "id": 31, "title": "Disk per node", "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 38 },
      "description": "Total / Used / Free + процент. Free = total - used (вычисляется на лету).",
      "options": { "showHeader": true, "footer": { "show": false }, "cellHeight": "sm" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Total" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
        ]},
        { "matcher": { "id": "byName", "options": "Used" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
        ]},
        { "matcher": { "id": "byName", "options": "Free" }, "properties": [
          { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 110 },
          { "id": "custom.cellOptions", "value": { "type": "color-text" } },
          { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
        ]},
        { "matcher": { "id": "byName", "options": "Usage" }, "properties": [
          { "id": "unit", "value": "percentunit" }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 }, { "id": "decimals", "value": 1 },
          { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 0.9 }
          ]}}
        ]}
      ]},
      "targets": [
        { "refId": "A", "expr": "panel_node_disk_total_bytes{instance=~\"$instance\"}", "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "B", "expr": "panel_node_disk_used_bytes{instance=~\"$instance\"}",  "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "C", "expr": "panel_node_disk_total_bytes{instance=~\"$instance\"} - panel_node_disk_used_bytes{instance=~\"$instance\"}", "legendFormat": "{{node}}", "format": "table", "instant": true },
        { "refId": "D", "expr": "panel_node_disk_used_bytes{instance=~\"$instance\"} / clamp_min(panel_node_disk_total_bytes{instance=~\"$instance\"}, 1)", "legendFormat": "{{node}}", "format": "table", "instant": true }
