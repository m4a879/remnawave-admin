{
  "annotations": { "list": [
    { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts", "type": "dashboard" }
  ]},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview", "type": "dashboards", "tags": ["remnawave","overview"], "asDropdown": false, "includeVars": true, "keepTime": true, "targetBlank": false }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "title": "HTTP RPS by status", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" }, "spanNulls": true, "showPoints": "never" }, "unit": "reqps" }, "overrides": [
        { "matcher": { "id": "byRegexp", "options": "/^5../" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
        { "matcher": { "id": "byRegexp", "options": "/^4../" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
      ]},
      "targets": [{ "refId": "A", "expr": "sum by (status) (rate(panel_http_requests_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 2, "title": "HTTP latency (p50 / p95 / p99)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3, "title": "5xx error rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "showLegend": false } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "gradientMode": "opacity", "showPoints": "never" }, "unit": "reqps", "noValue": "0" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(rate(panel_http_requests_total{instance=~\"$instance\",status=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx" }]
    },
    {
      "id": 4, "title": "4xx error rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "showLegend": false } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }, "unit": "reqps", "noValue": "0" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(rate(panel_http_requests_total{instance=~\"$instance\",status=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx" }]
    },
    {
      "id": 5, "title": "Requests in flight", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum by (method) (panel_http_requests_in_progress{instance=~\"$instance\"})", "legendFormat": "{{method}}" }]
    },
    {
      "id": 6, "title": "DB pool usage", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "showLegend": true, "placement": "bottom" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "unit": "short" }, "overrides": [
        { "matcher": { "id": "byName", "options": "size" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }, { "id": "custom.fillOpacity", "value": 0 }] }
      ]},
      "targets": [
        { "refId": "A", "expr": "panel_db_pool_used{instance=~\"$instance\"}", "legendFormat": "used" },
        { "refId": "B", "expr": "panel_db_pool_size{instance=~\"$instance\"}", "legendFormat": "size" }
      ]
    },
    {
      "id": 7, "title": "Pool saturation", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 14 },
      "description": "used/size — 1.0 means pool exhausted",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 0.8 },
        { "color": "red", "value": 0.95 }
      ]}, "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "panel_db_pool_used{instance=~\"$instance\"} / panel_db_pool_size{instance=~\"$instance\"}", "legendFormat": "saturation" }]
    },
    {
      "id": 8, "title": "Request rate (total)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 14 },
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "reqps" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(rate(panel_http_requests_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "rps" }]
    },
    {
      "id": 9, "title": "Top endpoints by RPS", "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "blue", "value": null },
        { "color": "orange", "value": 10 },
        { "color": "red", "value": 50 }
      ]}, "unit": "reqps" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "topk(10, sum by (path) (rate(panel_http_requests_total{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "{{path}}" }]
    },
    {
      "id": 10, "title": "Top endpoints by p95 latency", "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 0.5 },
        { "color": "red", "value": 2 }
      ]}, "unit": "s" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum by (path, le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval]))))", "legendFormat": "{{path}}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["remnawave", "panel", "http"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "options": [], "refresh": 1, "skipUrlSync": false },
      { "name": "instance", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(panel_online_users, instance)", "current": { "selected": false, "text": "All", "value": "$__all" }, "hide": 0, "includeAll": true, "label": "Instance", "multi": true, "options": [], "refresh": 2, "regex": "", "skipUrlSync": false, "sort": 1 }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Remnawave Admin — HTTP & Performance",
  "uid": "remnawave-panel-http",
  "version": 1,
  "weekStart": ""
}
