{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ConfigObject",
  "definitions": {
    "ConfigObject": {
      "type": "object",
      "title": "Xray-core Configuration",
      "additionalProperties": false,
      "properties": {
        "log": {
          "$ref": "#/definitions/LogObject"
        },
        "api": {
          "$ref": "#/definitions/ApiObject"
        },
        "metrics": {
          "$ref": "#/definitions/MetricsObject"
        },
        "dns": {
          "$ref": "#/definitions/DnsObject"
        },
        "routing": {
          "$ref": "#/definitions/RoutingObject"
        },
        "policy": {
          "$ref": "#/definitions/PolicyObject"
        },
        "inbounds": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/InboundObject"
          }
        },
        "outbounds": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/OutboundObject"
          }
        },
        "transport": {
          "$ref": "#/definitions/TransportObject"
        },
        "stats": {
          "$ref": "#/definitions/StatsObject"
        },
        "reverse": {
          "$ref": "#/definitions/ReverseObject"
        },
        "fakedns": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FakeDnsObject"
          }
        },
        "observatory": {
          "$ref": "#/definitions/ObservatoryObject"
        },
        "burstObservatory": {
          "$ref": "#/definitions/BurstObservatoryObject"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables for the Xray process (Xray 25.x+)"
        },
        "geodata": {
          "type": "object",
          "description": "Geodata files management (Xray 25.x+)"
        },
        "version": {
          "type": "string",
          "description": "Minimal required Xray version constraint (Xray 25.x+)"
        }
      }
    },
    "LogObject": {
      "type": "object",
      "properties": {
        "access": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "loglevel": {
          "enum": [
            "debug",
            "info",
            "warning",
            "error",
            "none"
          ],
          "description": "debug/info/warning/error/none — warning для прода"
        },
        "dnsLog": {
          "type": "boolean"
        },
        "maskAddress": {
          "type": "string"
        }
      }
    },
    "ApiObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string"
        },
        "listen": {
          "type": "string"
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "MetricsObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string"
        },
        "listen": {
          "type": "string"
        }
      }
    },
    "DnsObject": {
      "type": "object",
      "properties": {
        "servers": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "port": {
                    "type": "integer"
                  },
                  "domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "expectIPs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "skipFallback": {
                    "type": "boolean"
                  },
                  "clientIp": {
                    "type": "string"
                  },
                  "tag": {
                    "type": "string"
                  },
                  "queryStrategy": {
                    "enum": [
                      "UseIP",
                      "UseIPv4",
                      "UseIPv6"
                    ]
                  }
                }
              }
            ]
          },
          "description": "DNS-серверы: адрес, \"https://...\", \"fakedns\" и объекты с правилами"
        },
        "hosts": {
          "type": "object"
        },
        "clientIp": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "queryStrategy": {
          "enum": [
            "UseIP",
            "UseIPv4",
            "UseIPv6"
          ]
        },
        "disableCache": {
          "type": "boolean"
        },
        "disableFallback": {
          "type": "boolean"
        },
        "disableFallbackIfMatch": {
          "type": "boolean"
        }
      }
    },
    "RoutingObject": {
      "type": "object",
      "properties": {
        "domainStrategy": {
          "enum": [
            "AsIs",
            "IPIfNonMatch",
            "IPOnDemand"
          ],
          "description": "AsIs / IPIfNonMatch / IPOnDemand — как резолвить домены в правилах"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RoutingRule"
          },
          "description": "Правила маршрутизации, применяются сверху вниз до первого совпадения"
        },
        "balancers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BalancerObject"
          }
        }
      }
    },
    "RoutingRule": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "field"
        },
        "ruleTag": {
          "type": "string",
          "description": "Human-readable name for the rule."
        },
        "domain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Домены: full:, domain:, regexp:, geosite:категория"
        },
        "ip": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IP/CIDR или geoip:код (geoip:private — локальные сети)"
        },
        "port": {
          "type": "string"
        },
        "network": {
          "type": "string"
        },
        "source": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "user": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inboundTag": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protocol": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outboundTag": {
          "type": "string",
          "description": "Тег аутбаунда, куда уходит совпавший трафик"
        },
        "balancerTag": {
          "type": "string"
        },
        "attrs": {
          "type": "object"
        }
      }
    },
    "BalancerObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string"
        },
        "selector": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strategy": {
          "type": "object",
          "properties": {
            "type": {
              "enum": [
                "random",
                "roundRobin",
                "leastPing",
                "leastLoad"
              ]
            }
          }
        },
        "fallbackTag": {
          "type": "string"
        }
      }
    },
    "InboundObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string",
          "description": "Уникальный тег инбаунда (используется в роутинге и панели)"
        },
        "port": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ],
          "description": "Порт: число, \"env:VAR\" или диапазон \"1000-2000\""
        },
        "listen": {
          "type": "string",
          "description": "Адрес прослушивания: IP или unix domain socket"
        },
        "protocol": {
          "type": "string"
        },
        "settings": {
          "type": "object"
        },
        "streamSettings": {
          "$ref": "#/definitions/StreamSettingsObject"
        },
        "sniffing": {
          "type": "object",
          "description": "Определение целевого домена из трафика (для роутинга по доменам)"
        },
        "allocate": {
          "type": "object"
        }
      }
    },
    "OutboundObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string",
          "description": "Уникальный тег аутбаунда (цель outboundTag в роутинге)"
        },
        "sendThrough": {
          "type": "string",
          "description": "Исходящий IP при нескольких адресах на сервере"
        },
        "protocol": {
          "type": "string"
        },
        "settings": {
          "type": "object"
        },
        "streamSettings": {
          "$ref": "#/definitions/StreamSettingsObject"
        },
        "proxySettings": {
          "type": "object"
        },
        "mux": {
          "type": "object"
        }
      }
    },
    "StreamSettingsObject": {
      "type": "object",
      "properties": {
        "network": {
          "enum": [
            "tcp",
            "udp",
            "kcp",
            "ws",
            "http",
            "quic",
            "grpc",
            "xhttp",
            "raw",
            "httpupgrade",
            "hysteria"
          ],
          "description": "Транспорт: raw (бывш. tcp), ws, grpc, xhttp, httpupgrade, kcp, hysteria"
        },
        "security": {
          "enum": [
            "none",
            "tls",
            "reality"
          ],
          "description": "Шифрование транспорта: none / tls / reality"
        },
        "tlsSettings": {
          "type": "object",
          "description": "Классический TLS",
          "properties": {
            "serverName": {
              "type": "string",
              "description": "SNI"
            },
            "alpn": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "ALPN, напр. [\"h2\",\"http/1.1\"]"
            },
            "certificates": {
              "type": "array",
              "items": {
                "type": "object"
              },
              "description": "Сертификаты: certificateFile/keyFile или inline"
            },
            "rejectUnknownSni": {
              "type": "boolean",
              "description": "Отклонять неизвестные SNI"
            },
            "allowInsecure": {
              "type": "boolean",
              "description": "Клиент: не проверять сертификат (небезопасно)"
            },
            "fingerprint": {
              "type": "string",
              "description": "Клиент: uTLS-отпечаток"
            },
            "minVersion": {
              "type": "string",
              "description": "Мин. версия TLS, напр. \"1.2\""
            },
            "maxVersion": {
              "type": "string",
              "description": "Макс. версия TLS"
            }
          }
        },
        "realitySettings": {
          "type": "object",
          "description": "Reality: маскировка под настоящий TLS-сайт (target)",
          "properties": {
            "show": {
              "type": "boolean",
              "description": "Выводить отладочную информацию"
            },
            "target": {
              "type": "string",
              "description": "Куда проксировать TLS-рукопожатие (бывш. dest): \"host:port\""
            },
            "dest": {
              "type": "string",
              "description": "Устаревшее имя target (совместимость)"
            },
            "xver": {
              "type": "number",
              "description": "PROXY protocol версия к target (0 = выключен)"
            },
            "serverNames": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Разрешённые SNI клиентов (домен маскировки)"
            },
            "privateKey": {
              "type": "string",
              "description": "Приватный ключ x25519 сервера (кнопка «Ключи Reality»)"
            },
            "shortIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Список shortId клиентов (hex, допустима пустая строка)"
            },
            "minClientVer": {
              "type": "string",
              "description": "Минимальная версия клиента Xray"
            },
            "maxClientVer": {
              "type": "string",
              "description": "Максимальная версия клиента Xray"
            },
            "maxTimeDiff": {
              "type": "number",
              "description": "Допустимое расхождение времени, мс"
            },
            "fingerprint": {
              "type": "string",
              "description": "Клиент: uTLS-отпечаток (chrome/firefox/safari/random...)"
            },
            "serverName": {
              "type": "string",
              "description": "Клиент: SNI из serverNames сервера"
            },
            "publicKey": {
              "type": "string",
              "description": "Клиент: публичный ключ сервера (pbk)"
            },
            "shortId": {
              "type": "string",
              "description": "Клиент: shortId из списка сервера"
            },
            "spiderX": {
              "type": "string",
              "description": "Клиент: путь «паука» (обычно /)"
            }
          }
        },
        "tcpSettings": {
          "type": "object"
        },
        "kcpSettings": {
          "type": "object"
        },
        "wsSettings": {
          "type": "object",
          "description": "WebSocket",
          "properties": {
            "path": {
              "type": "string",
              "description": "Путь, напр. \"/ws\""
            },
            "host": {
              "type": "string",
              "description": "Значение Host (маскировка/CDN)"
            },
            "headers": {
              "type": "object",
              "description": "Дополнительные HTTP-заголовки"
            },
            "heartbeatPeriod": {
              "type": "number",
              "description": "Период пинга, сек"
            }
          }
        },
        "httpSettings": {
          "type": "object"
        },
        "quicSettings": {
          "type": "object"
        },
        "grpcSettings": {
          "type": "object",
          "description": "gRPC",
          "properties": {
            "serviceName": {
              "type": "string",
              "description": "Имя сервиса (аналог пути)"
            },
            "authority": {
              "type": "string",
              "description": "Значение :authority"
            },
            "multiMode": {
              "type": "boolean",
              "description": "Мульти-режим (экспериментальный)"
            }
          }
        },
        "xhttpSettings": {
          "type": "object",
          "description": "XHTTP (SplitHTTP): H2/H3 транспорт, дружит с CDN",
          "properties": {
            "path": {
              "type": "string",
              "description": "Путь, напр. \"/xh\""
            },
            "host": {
              "type": "string",
              "description": "Значение Host"
            },
            "mode": {
              "enum": [
                "auto",
                "packet-up",
                "stream-up",
                "stream-one"
              ],
              "description": "Режим передачи"
            },
            "extra": {
              "type": "object",
              "description": "Тонкие настройки (xPaddingBytes, scMaxEachPostBytes...)"
            }
          }
        },
        "httpupgradeSettings": {
          "type": "object",
          "description": "HTTPUpgrade: WS-подобный без WebSocket-фреймов",
          "properties": {
            "path": {
              "type": "string",
              "description": "Путь"
            },
            "host": {
              "type": "string",
              "description": "Значение Host"
            },
            "headers": {
              "type": "object",
              "description": "Дополнительные HTTP-заголовки"
            }
          }
        },
        "hysteriaSettings": {
          "type": "object"
        },
        "sockopt": {
          "$ref": "#/definitions/SockoptObject",
          "description": "Низкоуровневые опции сокета (mark, tcpFastOpen, domainStrategy...)"
        },
        "finalmask": {
          "$ref": "#/definitions/FinalmaskObject"
        }
      }
    },
    "SockoptObject": {
      "type": "object",
      "properties": {
        "mark": {
          "type": "integer"
        },
        "tcpFastOpen": {
          "type": "boolean"
        },
        "tproxy": {
          "enum": [
            "off",
            "tproxy",
            "redirect"
          ]
        },
        "v6only": {
          "type": "boolean"
        },
        "acceptProxyProtocol": {
          "type": "boolean"
        },
        "interface": {
          "type": "string"
        },
        "dialerProxy": {
          "type": "string"
        },
        "domainStrategy": {
          "enum": [
            "AsIs",
            "UseIP",
            "UseIPv4",
            "UseIPv6",
            "UseIPv4v6",
            "UseIPv6v4"
          ]
        },
        "tcpKeepAliveIdle": {
          "type": "integer"
        },
        "tcpKeepAliveInterval": {
          "type": "integer"
        },
        "tcpUserTimeout": {
          "type": "integer"
        },
        "tcpMaxSeg": {
          "type": "integer"
        },
        "tcpCongestion": {
          "type": "string"
        },
        "tcpWindowClamp": {
          "type": "integer"
        },
        "tcpMptcp": {
          "type": "boolean"
        },
        "tcpNoDelay": {
          "type": "boolean"
        }
      }
    },
    "FinalmaskObject": {
      "type": "object",
      "properties": {
        "tcp": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FinalmaskNoiseItem"
          }
        },
        "udp": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FinalmaskNoiseItem"
          }
        },
        "quicParams": {
          "type": "object"
        }
      }
    },
    "FinalmaskNoiseItem": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "noise"
          ]
        },
        "settings": {
          "type": "object",
          "properties": {
            "noise": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "enum": [
                      "hex",
                      "rand"
                    ]
                  },
                  "packet": {
                    "type": "string"
                  },
                  "rand": {
                    "type": "string"
                  },
                  "delay": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "TransportObject": {
      "type": "object"
    },
    "StatsObject": {
      "type": "object"
    },
    "PolicyObject": {
      "type": "object"
    },
    "ReverseObject": {
      "type": "object"
    },
    "FakeDnsObject": {
      "type": "object",
      "properties": {
        "ipPool": {
          "type": "string"
        },
        "poolSize": {
          "type": "integer"
        }
      }
    },
    "ObservatoryObject": {
      "type": "object"
    },
    "BurstObservatoryObject": {
      "type": "object"
    }
  }
}
